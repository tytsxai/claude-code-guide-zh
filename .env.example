# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).
# Locally:  set -a; source .env; set +a
# In CI:    store these as GitHub Actions Secrets, not in the repo.

# One or more DeepSeek API keys, comma-separated, for round-robin + failover.
DEEPSEEK_API_KEYS=sk-key1,sk-key2,sk-key3

# Model. The request asked for `deepseek-v4-flash`, which is NOT a real model yet.
# Real options today: deepseek-chat (V3.x) or deepseek-reasoner (R1).
# Switch to deepseek-v4-flash here the moment it actually ships.
DEEPSEEK_MODEL=deepseek-chat

# Optional overrides (defaults shown):
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# UPSTREAM_REPO=https://github.com/Cranot/claude-code-guide.git
# UPSTREAM_BRANCH=main
# MAX_CHUNK_CHARS=6000
# DEEPSEEK_TEMPERATURE=0.2
